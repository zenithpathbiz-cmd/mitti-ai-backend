# ══════════════════════════════════════════════
#  MITTI AI  —  Environment Variables
#  Copy to .env and fill in your values
# ══════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://mitti_user:your_password@localhost:5432/mitti_ai_db"

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES=30d

# Claude AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# SMS (MSG91) — leave empty for console OTP in dev
MSG91_KEY=
MSG91_SENDER=MITIAI
MSG91_TEMPLATE=

# Mandi Data (data.gov.in) — free registration at data.gov.in
AGMARKNET_KEY=

# Weather (OpenWeatherMap) — free at openweathermap.org
OPENWEATHER_KEY=

# Redis (for caching) — optional in dev
REDIS_URL=redis://localhost:6379

# Admin
ADMIN_PHONE=9999999999
